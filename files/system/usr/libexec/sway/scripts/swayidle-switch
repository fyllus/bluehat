#!/bin/bash

# Timeouts (in seconds)
stage1=300 # Low brightness
stage2=600 # Lockscreen
stage3=900 # Display off

# Commands
set_lock="gtklock -d"
set_display_on="(swaymsg 'output * power on' && brightnessctl set 5%) 2>/dev/null "
set_display_off="(brightnessctl -s && brightnessctl set 0% && swaymsg 'output * power off') 2>/dev/null"

# Toggle execution
if pgrep -f "swayidle" >/dev/null; then
    pkill -f swayidle
    notify-send "SwayIdle" "Idle/Lock desligado" -t 600
else
    # Arguments array to preserve tokenization without eval
    swayidle_args=(
        timeout "$stage1" "(brightnessctl -s && brightnessctl set 1%) 2>/dev/null"
        resume "$set_display_on"
        timeout "$stage2" "$set_lock"
        timeout "$stage3" "$set_display_off"
        before-sleep "$set_lock"
    )

    (swayidle -w "${swayidle_args[@]}") &

    notify-send "SwayIdle" "Idle/Lock ativado" -t 600
fi

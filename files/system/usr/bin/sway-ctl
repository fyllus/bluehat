#!/usr/bin/env bash

show-main-help() {
    cat << EOF
Usage: $(basename "$0") [action] <module> [options]

Core Modules (Direct or via 'get'/'set'):
  time                      Date and time information.
  memory                    Memory usage and space metrics.
  cpu                       Processor temperature and load.
  battery                   Battery level and status.
  wifi                      Wireless network interface status and SSID.
  idle-toggle               Enable/Disable swayidle background process.

Legacy Actions (Optional):
  get <module> [options]    Fetch system information.
  set <module>              Execute system configurations or actions.

Information:
  Use '$(basename "$0") <module> --help' for details on a specific module.
EOF
}

module-time() {
    case "$1" in
        --help)
            cat << EOF
Options for 'time' module:
  --default       Returns standard date and time format (ο¹≥  %c).
  --date-ext-1    Returns short day, date, and month (ο¹≥  %a %d %b).
  --time          Returns current time only (σΑΞî  %I:%M %p).
EOF
            ;;
        --default)
            date '+ο¹≥  %c'
            ;;
        --date-ext-1)
            date '+ο¹≥  %a %d %b'
            ;;
        --time)
            date '+σΑΞî  %I:%M %p'
            ;;
        *)
            show-main-help
            ;;
    esac
}

module-memory() {
    if [[ "$1" == "--help" ]]; then
        cat << EOF
Options for 'memory' module:
  --perc-using    Memory usage percentage (based on actual available memory).
  --perc-free     Available/free memory percentage.
  --mb-using      Memory usage converted to MB.
  --mb-free       Available memory converted to MB.
  --gb-using      Memory usage converted to GB.
  --gb-free       Available memory converted to GB.
EOF
        return
    fi

    local total free avail
    read -r total free avail < <(awk '/^MemTotal:/ {t=$2} /^MemFree:/ {f=$2} /^MemAvailable:/ {a=$2} END {print t, f, a}' /proc/meminfo)
    local used=$((total - avail))

    case "$1" in
        --perc-using) awk -v u="$used" -v t="$total" 'BEGIN {printf "νΩÖ  %.2f%%\n", (u/t)*100}' ;;
        --perc-free)  awk -v a="$avail" -v t="$total" 'BEGIN {printf "νΩÖ  %.2f%%\n", (a/t)*100}' ;;
        --mb-using)   awk -v u="$used" 'BEGIN {printf "νΩÖ  %.2f MB\n", u / 1024}' ;;
        --mb-free)    awk -v a="$avail" 'BEGIN {printf "νΩÖ  %.2f MB\n", a / 1024}' ;;
        --gb-using)   awk -v u="$used" 'BEGIN {printf "νΩÖ  %.2f GB\n", u / 1024 / 1024}' ;;
        --gb-free)    awk -v a="$avail" 'BEGIN {printf "νΩÖ  %.2f GB\n", a / 1024 / 1024}' ;;
        *)            show-main-help ;;
    esac
}

module-cpu() {
    case "$1" in
        --help)
            cat << EOF
Options for 'cpu' module:
  --temp     Current temperature read directly from /sys/class/thermal.
  --usage    Overall CPU usage calculated from /proc/stat.
EOF
            ;;
        --temp)
            if [ -f /sys/class/thermal/thermal_zone0/temp ]; then
                local raw_temp
                raw_temp=$(cat /sys/class/thermal/thermal_zone0/temp)
                printf "ο΄â %.1f¬ΑC\n" "$(awk -v t="$raw_temp" 'BEGIN {print t / 1000}')"
            fi
            ;;
        --usage)
            grep 'cpu ' /proc/stat | awk '{usage=($2+$4)*100/($2+$4+$5); printf "ο£Φ  %.0f%%\n", usage}'
            ;;
        *)
            show-main-help
            ;;
    esac
}

module-battery() {
    if [[ "$1" == "--help" ]]; then
        cat << EOF
Options for 'battery' module:
  --level    Displays dynamic icon based on status and percentage. Triggers notification if < 10%.
  *          Any other flag (or none) returns just the clean percentage string (e.g., 95%).
EOF
        return
    fi

    case "$1" in
        --level)
            local val icon idx
            local lock_file="/tmp/battery_low.lock"

            if [ -f /sys/class/power_supply/BAT0/capacity ]; then
                val=$(cat /sys/class/power_supply/BAT0/capacity)
            else
                val=$(cat /sys/class/power_supply/BAT*/capacity 2>/dev/null | head -n 1)
            fi

            local norm=("σΑ¹Κ" "σΑ¹Ϋ" "σΑ¹Ω" "σΑ²¹" "σΑ¹Ι")
            local plugged=("σΑΔ€" "σΑ²΅" "σΑΔù" "σΑ²ä" "σΑ²Ö")

            local -n icons
            if grep -qE 'Charging|Full' /sys/class/power_supply/BAT*/status 2>/dev/null; then
                icons=plugged
                rm -f "$lock_file"
            else
                icons=norm
            fi

            if (( val < 10 )); then idx=0
            elif (( val < 25 )); then idx=1
            elif (( val < 60 )); then idx=2
            elif (( val < 80 )); then idx=3
            else                      idx=4
            fi

            icon="${icons[$idx]}"

            if [[ "$icons" == "norm" && (( val < 10 )) ]]; then
                if [[ ! -f "$lock_file" ]]; then
                    touch "$lock_file"
                    notify-send -u critical "Battery" "You need to charge your device: $val%"
                fi
            elif [[ "$icons" == "norm" && (( val > 10 )) ]] && [[ -f "$lock_file" ]]; then
                rm -f "$lock_file"
            fi

            printf "%s %d%%\n" "$icon" "$val"
            ;;
         *)
            if [ -f /sys/class/power_supply/BAT0/capacity ]; then
                cat /sys/class/power_supply/BAT0/capacity | awk '{printf "%d%%\n", $1}'
            else
                cat /sys/class/power_supply/BAT*/capacity 2>/dev/null | head -n 1 | awk '{printf "%d%%\n", $1}'
            fi
            ;;
    esac
}
module-backlight() {
    case "$1" in
        --help)
            cat << EOF
Options for 'backlight' module:
  --list-devices            Lists available backlight targets in /sys/class/backlight.
  <device_name>             Returns the current brightness percentage for the specified device.
EOF
            ;;
        --list-devices)
            ls /sys/class/backlight
            ;;
        *)
            if [[ -z "$1" ]]; then
                show-main-help
                return
            fi

            local dev_dir="/sys/class/backlight/$1"
            if [[ -f "$dev_dir/brightness" && -f "$dev_dir/max_brightness" ]]; then
                local cur max
                cur=$(cat "$dev_dir/brightness")
                max=$(cat "$dev_dir/max_brightness")
                if (( max > 0 )); then
                    printf "σΑÉ†  %.2f%%\n" "$(awk -v c="$cur" -v m="$max" 'BEGIN {print (c/m)*100}')"
                else
                    echo "σΑÉ†  0%"
                fi
            else
                echo "σΑÉ†  Err"
            fi
            ;;
    esac
}
module-wifi() {
    if [[ "$1" == "--help" ]]; then
        cat << EOF
Options for 'wifi' module:
  --status    Returns active SSID with signal strength icon, or 'σΑΛ°  Disconnected'.
  --ip        Returns the private IPv4 address assigned to the wireless interface.
EOF
        return
    fi

    local interface=""
    for dev in /sys/class/net/*; do
        if [[ -d "$dev/wireless" ]]; then
            interface=$(basename "$dev")
            break
        fi
    done

    if [[ -z "$interface" ]] || [[ "$(cat /sys/class/net/"$interface"/operstate 2>/dev/null)" != "up" ]]; then
        case "$1" in
            --ip) echo "No IP" ;;
            *)    echo "σΑΛ°  Disconnected" ;;
        esac
        return
    fi

    case "$1" in
        --status)
            local ssid link quality icon idx
            ssid=$(iw dev "$interface" link | awk -F ': ' '/SSID/ {print $2}')
            [[ -z "$ssid" ]] && ssid="Unknown"

            # Fallback seguro para o cΟΓlculo de qualidade se o /proc/net/wireless nΟΘo existir
            if [[ -f /proc/net/wireless ]]; then
                link=$(awk -v iface="$interface" '$1 ~ iface {print $3}' /proc/net/wireless | tr -d '.')
                quality=$(( (link * 100) / 70 ))
            else
                # Se nΟΘo houver /proc/net/wireless, estima pelo sinal em dBm do 'iw'
                local dbm
                dbm=$(iw dev "$interface" link | awk '/signal:/ {print $2}')
                if [[ -n "$dbm" ]]; then
                    if (( dbm <= -100 )); then quality=0
                    elif (( dbm >= -50 )); then quality=100
                    else quality=$(( 2 * (dbm + 100) ))
                    fi
                else
                    quality=100
                fi
            fi

            local icons=("σΑΛ·" "σΑΛü" "σΑΛΔ" "σΑΛΞ" "σΑΛ®")
            if (( quality < 20 )); then   idx=0
            elif (( quality < 40 )); then idx=1
            elif (( quality < 60 )); then idx=2
            elif (( quality < 80 )); then idx=3
            else                          idx=4
            fi
            icon="${icons[$idx]}"

            printf "%s %s\n" "$icon" "$ssid"
            ;;
        --ip)
            ip addr show dev "$interface" | awk '/inet / {print $2}' | cut -d/ -f1 | head -n 1
            ;;
        *)
            show-main-help
            ;;
    esac
}

idle-toggle () {
    local stage1=300 stage2=600 stage3=900
    local set_lock="gtklock -d"
    local set_display_on="(swaymsg 'output * power on' && brightnessctl set 5%) 2>/dev/null "
    local set_display_off="(brightnessctl -s && brightnessctl set 0% && swaymsg 'output * power off') 2>/dev/null"

    if pgrep -f "swayidle" >/dev/null; then
        pkill -f swayidle
        notify-send "SwayIdle" "Idle/Lock disabled" -t 600
    else
        local swayidle_args=(
            timeout "$stage1" "(brightnessctl -s && brightnessctl set 1%) 2>/dev/null"
            resume "$set_display_on"
            timeout "$stage2" "$set_lock"
            timeout "$stage3" "$set_display_off"
            before-sleep "$set_lock"
        )
        (swayidle -w "${swayidle_args[@]}") &
        notify-send "SwayIdle" "Idle/Lock enabled" -t 600
    fi
}

main () {
    local token="$1"
    shift

    if [[ "$token" == "get" || "$token" == "set" ]]; then
        token="$1"
        shift
    fi

    case "$token" in
        time)        module-time "$@" ;;
        memory)      module-memory "$@" ;;
        cpu)         module-cpu "$@" ;;
        battery)     module-battery "$@" ;;
        wifi)        module-wifi "$@" ;;
        backlight)   module-backlight "$@" ;;
        idle-toggle) idle-toggle ;;
        --help|*)    show-main-help ;;
    esac
}
main "$@"
